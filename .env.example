# =========================================================================
#  Storyteller backend — environment variables
#  Copy to `.env` (local) or set on the server (production). Never commit .env.
# =========================================================================

# ---- AI (Google Gemini) -------------------------------------------------
# Cheie din https://aistudio.google.com/app/apikey (format nou AQ.... sau vechi AIzaSy...)
GEMINI_API_KEY=your_key_from_https://aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-2.5-flash

# ---- Core Django --------------------------------------------------------
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-in-production
# Set to False in production.
DJANGO_DEBUG=True
# Comma-separated hostnames (no scheme), e.g. api.example.com,example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database -----------------------------------------------------------
# In production set a full URL (managed Postgres / VPS):
#   DATABASE_URL=postgres://user:password@host:5432/dbname
# When DATABASE_URL is empty, the local DB_* values below are used.
# DATABASE_URL=
# DATABASE_SSL_REQUIRE=True
DB_NAME=storyteller
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432

# ---- CORS / CSRF (production only; include scheme) ----------------------
# CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# ---- Frontend URL (used in password-reset links) ------------------------
FRONTEND_URL=http://localhost:4200

# ---- Email (password reset). Console backend by default. ----------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey-or-user
# EMAIL_HOST_PASSWORD=secret
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@example.com

# ---- HTTPS hardening (only applied when DJANGO_DEBUG=False) --------------
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=2592000
